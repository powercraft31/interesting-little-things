# MQTT client-ID suffix – prevents collisions between environments.
# Use "local" for dev machines, "ec2" (or a unique tag) on EC2 instances.
MQTT_CLIENT_SUFFIX=local

# Strong JWT signing secret required by the v6.9 auth boundary.
# Generate with: openssl rand -hex 32
JWT_SECRET=

# Shared abuse-control backing store for production-capable BFF runtime.
# Local Docker default is redis://solfacil-redis:6379
RATE_LIMIT_REDIS_URL=redis://solfacil-redis:6379

# Emergency-only rollback toggle. Leave false or unset in normal operation.
LEGACY_BROWSER_BEARER=false
